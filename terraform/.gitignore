# Local .terraform directories
**/.terraform/*

# State files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Variable files with secrets — NEVER commit
*.tfvars
*.tfvars.json
!terraform.tfvars.example   # example file is OK to commit

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock file IS safe to commit (locks provider versions)
# .terraform.lock.hcl   <-- do NOT add this line
